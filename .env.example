# Copiar este archivo como .env y completar los valores

# PostgreSQL - Railway lo genera automáticamente
DATABASE_URL="postgresql://usuario:password@host:5432/billar_torneos"

# JWT - cambiar por un string largo y aleatorio en producción
JWT_SECRET="cambiar_por_un_secreto_largo_y_seguro"

# Puerto - Railway lo asigna automáticamente
PORT=3001

# En producción Railway usa la variable PORT del entorno automáticamente
